      "Vocabulary (37 tokens):\n",
      "['20thcenturystudios', 'a14', 'action', 'adventure', 'animation', 'cbs', 'columbiapictures', 'comedy', 'crime', 'dama', 'disney', 'drama', 'erotic', 'fantacy', 'fantasy', 'fiction', 'filmnationentertainment', 'fox', 'independent', 'newline', 'paramount', 'paramountpictures', 'romance', 'romantic', 'ronamtic', 'science', 'sherwoodpictures', 'sony', 'sonypictures', 'summit', 'teddyschwarzman', 'thewaltdisneycompany', 'theweinsteincompany', 'thriller', 'universal', 'waltdisneypictures', 'warnerbros']\n",
